generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourtType {
  V5 @map("5v5")
  V7 @map("7v7")
  V11 @map("11v11")
}

enum SurfaceType {
  artificial_grass
  natural_grass
}

model Court {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(100)
  nameAr        String        @map("name_ar") @db.VarChar(100)
  type          CourtType
  surface       SurfaceType
  capacity      Int
  hourlyRate    Decimal       @map("hourly_rate") @db.Decimal(10, 2)
  peakRate      Decimal       @map("peak_rate") @db.Decimal(10, 2)
  googleCalId   String?       @map("google_cal_id") @db.VarChar(255)
  locationLat   Decimal?      @map("location_lat") @db.Decimal(10, 8)
  locationLng   Decimal?      @map("location_lng") @db.Decimal(11, 8)
  mapsLink      String?       @map("maps_link")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  bookings      Booking[]
  pricingRules  PricingRule[]

  @@index([isActive])
  @@index([type])
  @@map("courts")
}

enum CustomerSegment {
  new
  occasional
  regular
  vip
}

enum Language {
  ar
  en
}

model Customer {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone         String          @unique @db.VarChar(20)
  name          String?         @db.VarChar(200)
  email         String?         @db.VarChar(255)
  preferredLang Language        @default(ar) @map("preferred_lang")
  segment       CustomerSegment @default(new)
  totalBookings Int             @default(0) @map("total_bookings")
  totalSpent    Decimal         @default(0) @map("total_spent") @db.Decimal(10, 2)
  firstContact  DateTime        @default(now()) @map("first_contact") @db.Timestamptz
  lastContact   DateTime        @default(now()) @map("last_contact") @db.Timestamptz
  preferences   Json            @default("{}")
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  bookings      Booking[]
  conversations Conversation[]

  @@index([segment])
  @@map("customers")
}

enum BookingType {
  regular
  birthday
  private_event
}

enum BookingStatus {
  confirmed
  cancelled
  completed
  no_show
}

model Booking {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  courtId       String        @map("court_id") @db.Uuid
  bookingType   BookingType   @default(regular) @map("booking_type")
  status        BookingStatus @default(confirmed)
  startTime     DateTime      @map("start_time") @db.Timestamptz
  endTime       DateTime      @map("end_time") @db.Timestamptz
  durationMins  Int           @map("duration_mins")
  price         Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  
  // Note: These tokens were mentioned in index requirements but not columns list
  cancelToken   String?       @unique @map("cancel_token") @db.VarChar(255)
  modifyToken   String?       @unique @map("modify_token") @db.VarChar(255)

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  court         Court         @relation(fields: [courtId], references: [id], onDelete: Restrict)
  eventExtras   EventExtra?

  @@index([customerId])
  @@index([courtId])
  @@index([status])
  @@index([courtId, startTime, endTime])
  @@map("bookings")
}

enum EventType {
  birthday
  corporate
  tournament
  private_event
}

model EventPackage {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String       @db.VarChar(100)
  nameAr               String       @map("name_ar") @db.VarChar(100)
  type                 EventType
  description          String?
  descriptionAr        String?      @map("description_ar")
  basePrice            Decimal      @map("base_price") @db.Decimal(10, 2)
  maxGuests            Int?         @map("max_guests")
  includesDecorations  Boolean      @default(false) @map("includes_decorations")
  includesCatering     Boolean      @default(false) @map("includes_catering")
  durationMins        Int          @map("duration_mins")
  isActive             Boolean      @default(true) @map("is_active")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz

  eventExtras          EventExtra[]

  @@index([type])
  @@index([isActive])
  @@map("event_packages")
}

model EventExtra {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String       @unique @map("booking_id") @db.Uuid
  packageId       String?      @map("package_id") @db.Uuid
  eventType       EventType    @map("event_type")
  guestCount      Int?         @map("guest_count")
  decorations     Boolean      @default(false)
  catering        Boolean      @default(false)
  specialRequests String?      @map("special_requests")
  packageName     String?      @map("package_name") @db.VarChar(100)
  packagePrice    Decimal?     @map("package_price") @db.Decimal(10, 2)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  booking         Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package         EventPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([packageId])
  @@map("event_extras")
}

model PricingRule {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courtId     String?   @map("court_id") @db.Uuid
  dayOfWeek   Int?      @map("day_of_week") // 0-6
  startHour   Int       @map("start_hour")
  endHour     Int       @map("end_hour")
  price       Decimal   @db.Decimal(10, 2)
  isPeak      Boolean   @default(false) @map("is_peak")
  validFrom   DateTime? @map("valid_from") @db.Date
  validUntil  DateTime? @map("valid_until") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  court       Court?    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId])
  @@index([dayOfWeek])
  @@map("pricing_rules")
}

enum Channel {
  whatsapp
  voice
}

enum ConversationStatus {
  active
  completed
  abandoned
}

enum Intent {
  booking
  cancellation
  inquiry
  event
  modification
}

model Conversation {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId  String?            @map("customer_id") @db.Uuid
  channel     Channel
  status      ConversationStatus @default(active)
  messages    Json               @default("[]")
  intent      Intent?
  resolved    Boolean            @default(false)
  startedAt   DateTime           @default(now()) @map("started_at") @db.Timestamptz
  endedAt     DateTime?          @map("ended_at") @db.Timestamptz

  customer    Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([channel])
  @@map("conversations")
}

enum AdminRole {
  owner
  manager
  staff
}

model AdminUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(200)
  role         AdminRole @default(staff)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([role])
  @@map("admin_users")
}
